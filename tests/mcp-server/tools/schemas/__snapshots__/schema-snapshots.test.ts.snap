exports[`Tool Schema Snapshots > Tool: stage_selected_specs_and_create_atomic_commit > inputSchema JSON output should be stable 1`] = `
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "commitSummary": {
      "description": "Human summary describing WHY these changes were made. This will be validated and refined into a conventional commit message.",
      "minLength": 1,
      "type": "string",
    },
    "fileSpecs": {
      "description": "List of file specs to stage. Supports whole file paths and line ranges in the format file#L10 or file#L10-L20.",
      "items": {
        "description": "File spec to stage. Supports whole file path or range: file#L10 or file#L10-L20.",
        "minLength": 1,
        "type": "string",
      },
      "minItems": 1,
      "type": "array",
    },
    "skipChecksIfHuskyPresent": {
      "default": true,
      "description": "If true (default), skips integrated quality checks when husky pre-commit hooks are configured to avoid duplicate runs. Set to false to ignore husky and run checks regardless.",
      "type": "boolean",
    },
    "skipPreStagedCheck": {
      "description": "If true, allows execution even when there are already staged changes. If false or omitted, tool fails when pre-existing staged changes are detected.",
      "type": "boolean",
    },
  },
  "required": [
    "fileSpecs",
    "commitSummary",
    "skipChecksIfHuskyPresent",
  ],
  "type": "object",
}
`;

exports[`Tool Schema Snapshots > Tool: stage_selected_specs_and_create_atomic_commit > outputSchema JSON output should be stable 1`] = `
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "commitHash": {
      "description": "Git commit hash for the created commit.",
      "type": "string",
    },
    "commitMessage": {
      "description": "Final conventional-commit style message used for git commit.",
      "type": "string",
    },
    "stagedFiles": {
      "description": "Files included in the created commit.",
      "items": {
        "description": "Repository-relative path of a staged file.",
        "type": "string",
      },
      "type": "array",
    },
    "stagedSpecs": {
      "description": "Original file specs processed for staging.",
      "items": {
        "description": "Original file spec submitted by the caller.",
        "type": "string",
      },
      "type": "array",
    },
  },
  "required": [
    "commitHash",
    "commitMessage",
    "stagedFiles",
    "stagedSpecs",
  ],
  "type": "object",
}
`;
