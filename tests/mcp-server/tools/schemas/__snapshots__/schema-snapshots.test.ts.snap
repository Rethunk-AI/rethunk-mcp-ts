              "exitCode",
              "duration",
            ],
            "type": "object",
          },
          {
            "additionalProperties": false,
            "properties": {
              "duration": {
                "description": "Execution time in milliseconds",
                "maximum": 9007199254740991,
                "minimum": 0,
                "type": "integer",
              },
              "exitCode": {
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991,
                "type": "integer",
              },
              "stderr": {
                "description": "Standard error output from the check",
                "type": "string",
              },
              "stdout": {
                "description": "Standard output from the check",
                "type": "string",
              },
              "success": {
                "const": false,
                "type": "boolean",
