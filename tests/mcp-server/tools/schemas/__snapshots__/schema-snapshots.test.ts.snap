exports[`Tool Schema Snapshots > Tool: check_typescript_project_for_problems > inputSchema JSON output should be stable 1`] = `
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "checks": {
      "description": "Specific checks to run. If not provided, runs all checks: lint:fix (which modifies files), typecheck, and typecheck:scripts.",
      "items": {
        "enum": [
          "lint:fix",
          "typecheck",
          "typecheck:scripts",
        ],
        "type": "string",
      },
      "type": "array",
    },
    "files": {
      "description": "Specific files to check. If provided, scopes the linting and type checking to these files only.",
      "items": {
        "description": "File path to check",
        "type": "string",
      },
      "type": "array",
    },
    "maxOutputLength": {
      "description": "Maximum length in characters for stdout and stderr fields. If output exceeds this, it will be truncated with a [...truncated] indicator. Ignored when summaryOnly=true.",
      "maximum": 9007199254740991,
      "minimum": 1,
      "type": "integer",
    },
    "summaryOnly": {
      "description": "If true, returns only exit codes, success status, and duration per check, omitting command and output fields. Useful for reducing output verbosity.",
      "type": "boolean",
    },
    "timeout": {
      "description": "Override timeout in milliseconds. Defaults to SDK context timeout. Use this for longer operations like running comprehensive tests.",
      "maximum": 9007199254740991,
      "minimum": 1,
      "type": "integer",
    },
  },
  "type": "object",
}
`;

