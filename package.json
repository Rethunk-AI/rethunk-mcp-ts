{
  "name": "rethunk-mcp-typescript",
  "version": "2.8.2",
  "mcpName": "com.rethunk/rethunk-mcp-typescript",
  "description": "Rethunk MCP for TypeScript: A production-grade MCP server implementation featuring powerful code inspection tools, atomic git commits with intelligent message validation, and a robust foundation for building scalable Model Context Protocol servers.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "rethunk-mcp-typescript": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": "./dist/*"
  },
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rethunk-AI/rethunk-mcp-ts.git"
  },
  "bugs": {
    "url": "https://github.com/Rethunk-AI/rethunk-mcp-ts/issues"
  },
  "homepage": "https://rethunk.ai/",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --external pino --external pino-pretty",
    "build:worker": "bun build ./src/worker.ts --outdir ./dist --target bun --no-external",
    "deploy:dev": "MCP_TRANSPORT_TYPE=http bunx wrangler dev",
    "deploy:prod": "MCP_TRANSPORT_TYPE=http bunx wrangler deploy",
    "start": "bun ./dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio bun ./dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http bun ./dist/index.js",
    "dev": "bun --watch src/index.ts",
    "dev:stdio": "MCP_LOG_LEVEL=debug MCP_TRANSPORT_TYPE=stdio bun --watch src/index.ts",
    "dev:http": "MCP_LOG_LEVEL=debug MCP_TRANSPORT_TYPE=http bun --watch src/index.ts",
    "devdocs": "bun run scripts/devdocs.ts",
    "rebuild": "bun run scripts/clean.ts && bun run build",
    "docs:generate": "bunx typedoc",
    "depcheck": "bunx depcheck",
    "lint": "bunx biome lint .",
    "typecheck": "bunx tsc --noEmit",
    "typecheck:scripts": "bunx tsc --project tsconfig.scripts.json --noEmit",
    "tree": "bun run scripts/tree.ts",
    "fetch-spec": "bun run scripts/fetch-openapi-spec.ts",
    "format": "bunx prettier --write \"**/*.{ts,js,json,md,html,css}\"",
    "prepare": "bunx husky",
    "inspector": "bunx mcp-inspector --config mcp.json --server rethunk-mcp-typescript",
    "test": "bunx vitest run",
    "test:coverage": "bunx vitest run --coverage",
    "coverage:update": "bun run scripts/update-coverage.ts",
    "coverage:commit": "bun run scripts/update-coverage.ts --commit",
    "audit": "bun audit",
    "audit:fix": "bun audit --fix",
    "publish-mcp": "bun scripts/validate-mcp-publish-schema.ts",
    "ci": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "resolutions": {
    "@hono/node-server": "2.0.4",
    "express-rate-limit": "8.3.2",
    "fast-uri": "3.1.2",
    "fast-xml-builder": "1.2.0",
    "handlebars": "4.7.9",
    "lodash": "4.17.23",
    "markdown-it": "14.1.1",
    "minimatch": "7.4.8",
    "picomatch": "4.0.4",
    "qs": "6.15.0",
    "yaml": "2.8.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@cloudflare/workers-types": "^5.20260718.1",
    "@hono/mcp": "^0.3.1",
    "@types/bun": "^1.3.14",
    "@types/diff": "^8.0.0",
    "@types/node": "^26.1.1",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/sanitize-html": "^2.16.1",
    "@types/validator": "^13.15.10",
    "@vitest/coverage-v8": "^4.1.10",
    "bun-types": "^1.3.14",
    "clipboardy": "^5.3.1",
    "depcheck": "^1.4.7",
    "execa": "^10.0.0",
    "fast-check": "^4.9.0",
    "husky": "^9.1.7",
    "ignore": "^7.0.6",
    "msw": "^2.15.0",
    "repomix": "^1.16.1",
    "typedoc": "^0.28.20",
    "vite": "^8.1.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "agent",
    "ai",
    "ai-agent",
    "authentication",
    "cloudflare-workers",
    "declarative-tools",
    "dependency-injection",
    "error-handling",
    "hono",
    "llm-integration",
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "elicitation",
    "observability",
    "opentelemetry",
    "otel",
    "server-template",
    "template",
    "typescript",
    "zod"
  ],
  "author": "Damon Blais <damon@rethunk.ai> (@AlbinoGeek) for Rethunk.Tech, LLC",
  "license": "Apache-2.0",
  "funding": [
    {
      "type": "other",
      "url": "https://rethunk.ai/"
    }
  ],
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=20.0.0"
  },
  "depcheck": {
    "ignores": [
      "bun",
      "repomix",
      "mcp-ts-template"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.16",
    "@hono/node-server": "^2.0.10",
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/instrumentation-pino": "^0.66.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/sdk-trace-node": "^2.9.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@supabase/supabase-js": "^2.110.7",
    "ai": "^7.0.31",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.18.1",
    "chrono-node": "^2.10.0",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.10.1",
    "hono": "^4.12.30",
    "jose": "^6.2.3",
    "js-yaml": "^5.2.1",
    "node-cron": "^4.6.0",
    "openai": "^6.48.0",
    "papaparse": "^5.5.4",
    "partial-json": "^0.1.7",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "sanitize-html": "^2.17.6",
    "surrealdb": "^2.0.4",
    "tslib": "^2.8.1",
    "tsyringe": "^4.10.0",
    "typescript": "^7.0.2",
    "unpdf": "^1.6.2",
    "validator": "^13.15.35",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@hono/node-server": "^2.0.4",
    "express-rate-limit": "^8.3.2",
    "fast-uri": "^3.1.2",
    "fast-xml-builder": "^1.2.0",
    "lodash": "^4.18.1",
    "zod": "4.4.3"
  }
}
